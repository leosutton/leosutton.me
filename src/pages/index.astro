---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout>
  <section class="hero container" aria-labelledby="page-title">
    <p class="eyebrow">Professional profile</p>
    <h1 id="page-title">Leo Sutton helps teams turn complexity into clear operating rhythm.</h1>
    <p class="hero-summary">
      I work at the intersection of finance, transformation, governance, and practical AI-enabled ways of working — helping organisations clarify priorities, improve decisions, and make execution more reliable.
    </p>
    <div class="hero-actions" aria-label="Primary actions">
      <a class="button primary" href="mailto:leo.sutton@protonmail.com">Contact Leo</a>
      <a class="button" href="#focus">View focus areas</a>
    </div>
  </section>

  <section id="profile" class="section">
    <div class="container section-grid">
      <div><h2>Profile</h2></div>
      <div>
        <p class="lede">
          A professional profile for work that benefits from structured thinking: commercial judgement, delivery discipline, pragmatic systems, and better use of emerging AI tools.
        </p>
        <p>
          This site is intentionally concise. It is designed to make it easy for collaborators, clients, and professional contacts to understand what I focus on, where I can help, and how to get in touch.
        </p>
      </div>
    </div>
  </section>

  <section id="focus" class="section">
    <div class="container section-grid">
      <div><h2>Focus</h2></div>
      <div>
        <p class="lede">The through-line is practical transformation: better decisions, better cadence, and better systems.</p>
        <div class="cards">
          <article class="card">
            <h3>Finance & commercial clarity</h3>
            <p>Turning financial and commercial context into clearer decisions, priorities, and trade-offs.</p>
          </article>
          <article class="card">
            <h3>Operating rhythm</h3>
            <p>Helping teams create reliable planning, review, governance, and follow-through habits.</p>
          </article>
          <article class="card">
            <h3>AI-enabled working</h3>
            <p>Applying AI tools where they improve judgement, coordination, automation, and execution — without losing human control.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="work" class="section">
    <div class="container section-grid">
      <div><h2>How I work</h2></div>
      <div>
        <p class="lede">I prefer useful clarity over theatre: fewer vague strategies, more concrete operating choices.</p>
        <ul class="list">
          <li>Make priorities explicit, including what will not be done.</li>
          <li>Connect strategy, finance, delivery, and governance into one operating picture.</li>
          <li>Create lightweight systems that reduce avoidable coordination cost.</li>
          <li>Use AI and automation as practical leverage, with safe defaults and transparent decision points.</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <div class="container contact-panel">
      <p class="eyebrow">Contact</p>
      <h2>For professional conversations, start with email.</h2>
      <p class="lede">
        If you want to discuss finance, transformation, operating cadence, or practical AI-enabled workflows, you can reach me at
        <a href="mailto:leo.sutton@protonmail.com">leo.sutton@protonmail.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>
